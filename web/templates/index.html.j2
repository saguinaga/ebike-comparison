<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
  <meta http-equiv="Pragma" content="no-cache">
  <meta http-equiv="Expires" content="0">
  <title>E-Bike &amp; Scooter Comparison · Surf City HB</title>
  <link rel="stylesheet" href="styles.css?v={{ asset_version }}">
  <script>
    (function () {
      var BUILD = "{{ asset_version }}";
      var key = "ebike_asset_build";
      try {
        if (localStorage.getItem(key) !== BUILD) {
          localStorage.setItem(key, BUILD);
          if (!sessionStorage.getItem("ebike_bust_" + BUILD)) {
            sessionStorage.setItem("ebike_bust_" + BUILD, "1");
            location.reload();
          }
        }
      } catch (_) {}
    })();
  </script>
  <script>
    (function () {
      if (location.search.indexOf("_recover=") !== -1) return;
      function recover() {
        try {
          if (sessionStorage.getItem("ebike_asset_recover")) return;
          sessionStorage.setItem("ebike_asset_recover", "1");
        } catch (_) {}
        var url = new URL(location.href);
        url.searchParams.set("_recover", String(Date.now()));
        location.replace(url.toString());
      }
      window.addEventListener(
        "error",
        function (e) {
          var t = e.target;
          if (t && (t.tagName === "SCRIPT" || t.tagName === "LINK")) recover();
        },
        true
      );
    })();
  </script>
</head>
<body>
{% macro brake_label(display) -%}
<span class="brake-label{% if display.css_class %} {{ display.css_class }}{% endif %}" title="{{ display.label }}">{%- if not display.glyph %}{{ display.icon }} {%- endif %}{{ display.label }}</span>
{%- endmacro %}
{% macro battery_block(display) -%}
<div class="battery-equip">
  <span class="battery-equip-title">Battery &amp; range</span>
  <ul class="battery-facts">
    <li><span class="bf-label">Range</span><span class="fact-value">{{ display.range_label }}</span></li>
    <li><span class="bf-label">Capacity</span><span class="fact-value">{{ display.capacity_label }}</span></li>
    <li><span class="bf-label">Charging</span><span class="fact-value">{{ display.charge_label }}{% if display.charge_notes %}<span class="bf-note" title="{{ display.charge_notes }}">ⓘ</span>{% endif %}</span></li>
    {% if display.efficiency_label and display.efficiency_label != '—' %}
    <li><span class="bf-label">Efficiency</span><span class="fact-value"><span class="efficiency-tag efficiency-readout efficiency-{{ display.efficiency_rating or 'unknown' }}">{{ display.efficiency_label }}</span></span></li>
    {% endif %}
  </ul>
</div>
{%- endmacro %}
{% macro feature_block(checklist, display) -%}
{% if checklist %}
<div class="feature-equip">
  <span class="feature-equip-title">Smart &amp; luxury <span class="luxury-score-badge">★ {{ display.luxury_score }}</span></span>
  <ul class="feature-facts">
    {% for group_id, group_label in [('security','Security'),('tracking','Tracking'),('app','App'),('audio','Audio'),('luxury','Premium')] %}
    {% set group_items = checklist | selectattr('group', 'equalto', group_id) | list %}
    {% if group_items %}
    <li class="feature-group-row"><span class="bf-label">{{ group_label }}</span><span class="feature-tags">{% for item in group_items %}<span class="feature-tag{% if item.ok %} ok{% else %} miss{% endif %}" title="{{ item.label }}">{{ item.label }}</span>{% endfor %}</span></li>
    {% endif %}
    {% endfor %}
  </ul>
</div>
{% endif %}
{%- endmacro %}
  <header class="hero" aria-label="Surf City Huntington Beach">
    <div class="hero-scene" aria-hidden="true">
      <div class="hero-sky"></div>
      <div class="hero-sun"></div>
      <svg class="hero-clouds" viewBox="0 0 1200 80" preserveAspectRatio="none">
        <ellipse cx="180" cy="28" rx="90" ry="18" fill="rgba(255,255,255,0.22)"/>
        <ellipse cx="260" cy="32" rx="55" ry="12" fill="rgba(255,255,255,0.16)"/>
        <ellipse cx="820" cy="22" rx="110" ry="20" fill="rgba(255,255,255,0.18)"/>
        <ellipse cx="940" cy="30" rx="70" ry="14" fill="rgba(255,255,255,0.12)"/>
      </svg>
      <svg class="pier-silhouette" viewBox="0 0 400 60" preserveAspectRatio="xMidYMax meet">
        <rect x="0" y="38" width="400" height="3" fill="rgba(0,0,0,0.18)"/>
        <rect x="20" y="12" width="4" height="29" fill="rgba(0,0,0,0.22)"/>
        <rect x="60" y="18" width="4" height="23" fill="rgba(0,0,0,0.2)"/>
        <rect x="100" y="10" width="4" height="31" fill="rgba(0,0,0,0.24)"/>
        <rect x="140" y="16" width="4" height="25" fill="rgba(0,0,0,0.2)"/>
        <rect x="180" y="8" width="4" height="33" fill="rgba(0,0,0,0.26)"/>
        <rect x="220" y="14" width="4" height="27" fill="rgba(0,0,0,0.2)"/>
        <rect x="260" y="11" width="4" height="30" fill="rgba(0,0,0,0.22)"/>
        <rect x="300" y="17" width="4" height="24" fill="rgba(0,0,0,0.18)"/>
        <rect x="340" y="13" width="4" height="28" fill="rgba(0,0,0,0.2)"/>
        <rect x="380" y="20" width="4" height="21" fill="rgba(0,0,0,0.16)"/>
      </svg>
      <div class="hero-ocean">
        <svg class="waves waves-back" viewBox="0 0 1440 100" preserveAspectRatio="none">
          <path d="M0,55 C180,30 360,70 540,50 C720,30 900,65 1080,48 C1260,32 1380,58 1440,45 L1440,100 L0,100 Z" fill="rgba(255,255,255,0.08)"/>
        </svg>
        <svg class="waves waves-mid" viewBox="0 0 1440 100" preserveAspectRatio="none">
          <path d="M0,62 C200,38 400,72 600,52 C800,34 1000,68 1200,50 C1320,40 1400,60 1440,52 L1440,100 L0,100 Z" fill="rgba(255,255,255,0.14)"/>
        </svg>
        <svg class="waves waves-front" viewBox="0 0 1440 100" preserveAspectRatio="none">
          <path d="M0,70 C160,48 320,78 480,60 C640,44 800,74 960,58 C1120,44 1280,72 1440,62 L1440,100 L0,100 Z" fill="rgba(255,255,255,0.22)"/>
        </svg>
      </div>
      <div class="hero-shore"></div>
      <svg class="palm palm-left" viewBox="0 0 140 220" fill="currentColor">
        <path d="M68 218 L68 95 Q68 88 72 82 L68 218Z" opacity="0.9"/>
        <path d="M72 82 Q20 55 8 18 Q35 42 58 72 Q30 35 42 5 Q58 38 68 68 Q72 30 95 8 Q78 42 72 72 Q98 40 118 12 Q95 48 74 78 Q115 55 132 28 Q100 62 72 82Z"/>
      </svg>
      <svg class="palm palm-right" viewBox="0 0 140 220" fill="currentColor">
        <path d="M68 218 L68 95 Q68 88 72 82 L68 218Z" opacity="0.9"/>
        <path d="M72 82 Q20 55 8 18 Q35 42 58 72 Q30 35 42 5 Q58 38 68 68 Q72 30 95 8 Q78 42 72 72 Q98 40 118 12 Q95 48 74 78 Q115 55 132 28 Q100 62 72 82Z"/>
      </svg>
    </div>
    <div class="hero-content">
      <span class="hero-badge">Surf City · Huntington Beach</span>
      <h1>E-Bike &amp; Scooter Comparison</h1>
      <p class="hero-sub">{{ ebike_count }} e-bikes · {{ scooter_count }} e-scooters · school &amp; commute · Huntington Beach</p>
      <nav class="quick-links">
        <a href="#bikes">Browse</a>
        <a href="#" id="heroCompareLink" hidden>Compare</a>
        <a href="#charts-section">Charts</a>
        <a href="#table-section">Table</a>
        <a href="#legal">Laws</a>
        <a href="#safety">Safety</a>
      </nav>
    </div>
  </header>

  <div class="container">
    <div id="browseView">
    <div class="user-controls" id="userControls">
      <button type="button" class="btn-secondary" id="btnAddBike">+ Add bike (URL)</button>
      <button type="button" class="btn-secondary" id="btnRestoreHidden" hidden>Restore hidden (<span id="hiddenCount">0</span>)</button>
      <button type="button" class="btn-ghost" id="btnResetPrefs" title="Clear hidden bikes, custom bikes, and baseline choice">Reset preferences</button>
    </div>

    <section class="section" id="bikes">
      <h2 class="section-title">Browse Rides</h2>
      <div class="toolbar" id="cardToolbar">
        <label>Type
          <select id="vehicleFilter">
            <option value="all">All</option>
            <option value="ebike">E-bikes only</option>
            <option value="scooter">E-scooters only</option>
          </select>
        </label>
        <label><input type="checkbox" id="colorFilter"> Highlight beach tones <span class="filter-hint">(white, sand, vanilla, light wood)</span></label>
        <label><input type="checkbox" id="smartFilter"> Highlight smart rides <span class="filter-hint">(app + GPS or lock)</span></label>
        <label>Max speed
          <select id="speedFilter">
            <option value="all">Any</option>
            <option value="under20">Under 20 mph</option>
            <option value="20">20 mph</option>
            <option value="28">28 mph</option>
          </select>
        </label>
        <label>Legal for age 12
          <select id="legalFilter">
            <option value="all">All</option>
            <option value="yes">Legal only</option>
            <option value="no">Illegal only</option>
          </select>
        </label>
        <label>Max price
          <select id="priceFilter">
            <option value="all">Any</option>
            <option value="600">Under $600</option>
            <option value="1200">Under $1,200</option>
            <option value="2000">Under $2,000</option>
          </select>
        </label>
        <label>Max weight
          <select id="weightFilter">
            <option value="all">Any</option>
            <option value="40">≤40 lb (kid solo)</option>
            <option value="55">≤55 lb (manageable)</option>
            <option value="70">≤70 lb</option>
          </select>
        </label>
        <label><input type="checkbox" id="lightFilter"> Highlight light rides <span class="filter-hint">(≤55 lb)</span></label>
        <label><input type="checkbox" id="efficiencyFilter"> Highlight efficient <span class="filter-hint">(≤12 Wh/mi PAS)</span></label>
      </div>
      <div class="tier-tabs" id="tierTabs">
        <button class="tier-tab active" data-tier="all">All</button>
        {% for tier, label in tier_labels.items() if tier != 'baseline' %}
        <button class="tier-tab" data-tier="{{ tier }}">{{ label }}</button>
        {% endfor %}
      </div>
      <div class="card-grid" id="cardGrid">
        {% for bike in bikes %}
        <article class="bike-card bike-card-compact"
          data-id="{{ bike.id }}"
          data-tier="{{ bike.tier }}"
          data-price="{{ bike.landed_price_usd or bike.price_usd }}"
          data-legal="{{ 'yes' if bike.legal.legal_for_age else 'no' }}"
          data-colors="{{ bike.colors | map(attribute='family') | join(',') }}"
          data-class="{{ 'scooter' if bike.vehicle_type == 'scooter' else bike.e_bike_class }}"
          data-speed="{{ bike.max_speed_mph }}"
          data-weight="{{ bike.weight_lb or '' }}"
          data-efficiency="{{ bike.battery_display.wh_per_mile_pas or '' }}"
          data-vehicle="{{ bike.vehicle_type or 'ebike' }}"
          data-luxury="{{ bike.feature_display.luxury_score if bike.feature_display else 0 }}"
          data-smart="{{ 'yes' if bike.feature_display and bike.feature_display.is_smart else 'no' }}">
          <button type="button" class="card-open" data-id="{{ bike.id }}" aria-label="View {{ bike.brand }} {{ bike.model }} details">
            <div class="bike-media">
              <div class="bike-thumb bike-thumb-compact">
                {% if bike.image_gallery %}
                <img class="bike-main-img" src="{{ bike.image_gallery[0] }}" alt="{{ bike.brand }} {{ bike.model }}" loading="lazy">
                {% elif bike.image_src %}
                <img class="bike-main-img" src="{{ bike.image_src }}" alt="{{ bike.brand }} {{ bike.model }}" loading="lazy">
                {% else %}
                <span class="placeholder-icon">🚲</span>
                {% endif %}
              </div>
            </div>
            <h3>{{ bike.brand }} {{ bike.model }}{% if bike.vehicle_type == 'scooter' %} <span class="badge vehicle-scooter">Scooter</span>{% endif %}</h3>
            <div class="price-big">${{ bike.landed_price_usd or bike.price_usd }}</div>
            {% if bike.weight_lb %}
            <div class="card-weight card-weight--js" data-weight="{{ bike.weight_lb }}">{{ bike.weight_lb }} lb</div>
            {% else %}
            <div class="card-weight card-weight--unknown">Weight —</div>
            {% endif %}
            <div class="badges badges-compact">
              <span class="badge ok">Safety {{ bike.safety_score }}</span>
              {% if bike.legal.legal_for_age %}
              <span class="badge ok">{% if bike.vehicle_type == 'scooter' %}OK{% else %}Legal{% endif %}</span>
              {% else %}
              <span class="badge danger">✗</span>
              {% endif %}
              {% if bike.feature_display and bike.feature_display.is_smart %}
              <span class="badge luxury">Smart</span>
              {% endif %}
            </div>
          </button>
          <div class="card-actions card-actions-compact">
            <button type="button" class="btn-compare" data-id="{{ bike.id }}">+ Compare</button>
            <button type="button" class="btn-hide" data-id="{{ bike.id }}" title="Hide from view">Hide</button>
          </div>
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="baseline-panel baseline-panel--compact" id="baselinePanel">
      <div class="baseline-bar">
        <h2 class="baseline-title">Comparison baseline</h2>
        <label class="baseline-picker">Compare against
          <select id="baselineSelect" aria-label="Select comparison baseline"></select>
        </label>
        <button type="button" class="btn-ghost btn-baseline-toggle" id="btnBaselineExpand" aria-expanded="false">Show details</button>
      </div>
      <div class="baseline-expanded" id="baselineExpanded" hidden>
        <div id="baselineMedia" class="bike-media"></div>
        <div id="baselineDetails" class="baseline-info"></div>
      </div>
    </section>

    <div class="wave-section" aria-hidden="true">
      <svg class="shore-wave shore-wave-top" viewBox="0 0 1200 48" preserveAspectRatio="none">
        <path d="M0,24 C150,4 300,40 450,20 C600,6 750,36 900,18 C1050,4 1125,28 1200,16 L1200,0 L0,0 Z" fill="var(--ocean-light)" opacity="0.35"/>
        <path d="M0,32 C200,14 400,44 600,26 C800,10 1000,40 1200,24 L1200,48 L0,48 Z" fill="var(--ocean)" opacity="0.2"/>
      </svg>
      <svg class="shore-wave shore-wave-bottom" viewBox="0 0 1200 48" preserveAspectRatio="none">
        <path d="M0,20 C180,38 360,8 540,28 C720,42 900,12 1080,30 C1140,36 1170,22 1200,26 L1200,48 L0,48 Z" fill="var(--sand-dark)" opacity="0.55"/>
        <path d="M0,30 C240,12 480,40 720,22 C960,8 1080,34 1200,28 L1200,48 L0,48 Z" fill="var(--foam)"/>
      </svg>
    </div>

    <section class="section" id="charts-section">
      <h2 class="section-title">Safety &amp; Energy Snapshots</h2>
      <p class="section-note">Based on visible bikes (respects hide &amp; filters). Energy uses manufacturer PAS range ÷ pack Wh — lower Wh/mi means less draw per mile.</p>
      <div class="charts-grid">
        <div class="chart-card"><h4>Safety vs price</h4><div id="chartSafetyPrice" class="chart-area"></div></div>
        <div class="chart-card"><h4>Safety by tier</h4><div id="chartSafetyTier" class="chart-area"></div></div>
        <div class="chart-card"><h4>Equipment pass rate</h4><div id="chartChecklist" class="chart-area"></div></div>
        <div class="chart-card"><h4>Max speed vs safety</h4><div id="chartSpeedSafety" class="chart-area"></div></div>
        <div class="chart-card"><h4>Range vs price</h4><div id="chartRangePrice" class="chart-area"></div></div>
        <div class="chart-card"><h4>Efficiency vs price</h4><div id="chartEfficiencyPrice" class="chart-area"></div></div>
        <div class="chart-card"><h4>Wh/mi by tier</h4><div id="chartEfficiencyTier" class="chart-area"></div></div>
        <div class="chart-card"><h4>Smart score vs price</h4><div id="chartLuxuryPrice" class="chart-area"></div></div>
      </div>
    </section>

    <section class="section" id="table-section">
      <h2 class="section-title">Overview Table</h2>
      <p style="font-size:0.85rem;color:#666;margin:-8px 0 10px;">Click column headers to sort. Use filters to narrow results.</p>
      <div class="table-toolbar">
        <label>Tier <select id="tableTierFilter"><option value="all">All</option>
          {% for tier, label in tier_labels.items() if tier != 'baseline' %}
          <option value="{{ tier }}">{{ label }}</option>
          {% endfor %}
        </select></label>
        <label>Type <select id="tableClassFilter"><option value="all">All</option><option value="1">Class 1</option><option value="2">Class 2</option><option value="3">Class 3</option><option value="scooter">Scooter</option></select></label>
        <label>Legal <select id="tableLegalFilter"><option value="all">All</option><option value="yes">Legal</option><option value="no">Illegal</option></select></label>
        <label><input type="checkbox" id="tableColorFilter"> Highlight beach tones <span class="filter-hint">(white, sand, vanilla, light wood)</span></label>
      </div>
      <table class="compare" id="compareTable">
        <thead>
          <tr>
            <th class="col-photo">Photo</th>
            <th data-sort="name" data-type="string">Bike</th>
            <th data-sort="price" data-type="number">Price</th>
            <th data-sort="safety" data-type="number">Safety</th>
            <th data-sort="weight" data-type="number" title="Lower is easier to carry">Weight</th>
            <th data-sort="class" data-type="string">Type</th>
            <th data-sort="luxury" data-type="number">Smart</th>
            <th data-sort="legal" data-type="string">Legal</th>
            <th data-sort="speed" data-type="number">Max mph</th>
            <th data-sort="range" data-type="number">Range mi</th>
            <th data-sort="battery" data-type="number">Battery</th>
            <th data-sort="efficiency" data-type="number" title="Lower Wh/mi = more efficient">Wh/mi</th>
            <th data-sort="charge" data-type="string">Charging</th>
            <th data-sort="brakes" data-type="string">Brakes</th>
            <th>Buy</th>
          </tr>
        </thead>
        <tbody>
          {% for bike in bikes %}
          <tr data-id="{{ bike.id }}"
              data-tier="{{ bike.tier }}"
              data-class="{{ 'scooter' if bike.vehicle_type == 'scooter' else bike.e_bike_class }}"
              data-legal="{{ 'yes' if bike.legal.legal_for_age else 'no' }}"
              data-colors="{{ bike.colors | map(attribute='family') | join(',') }}"
              data-name="{{ bike.brand }} {{ bike.model }}"
              data-price="{{ bike.landed_price_usd or bike.price_usd }}"
              data-safety="{{ bike.safety_score }}"
              data-weight="{{ bike.weight_lb or '' }}"
              data-speed="{{ bike.max_speed_mph }}"
              data-range="{{ bike.battery_range_miles_pas or '' }}"
              data-battery="{{ bike.battery_capacity_ah or '' }}"
              data-efficiency="{{ bike.battery_display.wh_per_mile_pas or '' }}"
              data-charge="{{ bike.battery_display.charge_label }}"
              data-brakes="{{ bike.brake_type }}"
              data-luxury="{{ bike.feature_display.luxury_score if bike.feature_display else '' }}"
              data-vehicle="{{ bike.vehicle_type or 'ebike' }}">
            <td class="table-photo">
              {% if bike.image_src %}
              <img src="{{ bike.image_src }}" alt="{{ bike.brand }} {{ bike.model }}" loading="lazy" title="{{ bike.brand }} {{ bike.model }}">
              {% else %}—{% endif %}
            </td>
            <td>{{ bike.brand }} {{ bike.model }}</td>
            <td>{{ (bike.landed_price_usd or bike.price_usd) | format_usd }}</td>
            <td>{{ bike.safety_score }}</td>
            <td>{% if bike.weight_lb %}{{ bike.weight_lb }} lb{% else %}—{% endif %}</td>
            <td>{% if bike.vehicle_type == 'scooter' %}Scooter{% else %}Class {{ bike.e_bike_class }}{% endif %}</td>
            <td>{% if bike.feature_display and bike.feature_display.luxury_score %}{{ bike.feature_display.luxury_score }}{% else %}—{% endif %}</td>
            <td>{{ 'Yes' if bike.legal.legal_for_age else 'No' }}</td>
            <td>{{ bike.max_speed_mph }}</td>
            <td>{{ bike.battery_display.range_label }}</td>
            <td>{{ bike.battery_display.capacity_label }}</td>
            <td>{% if bike.battery_display.wh_per_mile_pas %}<span class="efficiency-tag efficiency-{{ bike.battery_display.efficiency_rating or 'unknown' }}">{{ bike.battery_display.wh_per_mile_pas }}</span>{% else %}—{% endif %}</td>
            <td>{{ bike.battery_display.charge_label }}</td>
            <td>{{ brake_label(bike.brake_display) }}</td>
            <td class="buy-cell">
              {% if bike.best_buy_url %}
              <a href="{{ bike.best_buy_url }}" target="_blank" rel="noopener">{{ bike.best_buy_platform }}</a>
              {% if bike.price_sources|length > 1 %}<span class="alt-count">+{{ bike.price_sources|length - 1 }}</span>{% endif %}
              {% else %}—{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="section" id="legal">
      <h2 class="section-title">California + Huntington Beach</h2>
      <p class="disclaimer">{{ legal.disclaimer }} Helmets required under 18 (assumed for all rides).</p>
      {% for rule in legal.california %}
      <div class="legal-item"><strong>{{ rule.title }}</strong> — {{ rule.summary }} <a href="{{ rule.source }}" target="_blank" rel="noopener">Source</a></div>
      {% endfor %}
      {% for rule in legal.huntington_beach %}
      <div class="legal-item"><strong>{{ rule.title }}</strong> — {{ rule.summary }} <a href="{{ rule.source }}" target="_blank" rel="noopener">Source</a></div>
      {% endfor %}
      {% if legal.scooters %}
      <h3 style="margin-top:18px;font-size:1rem;">E-scooters</h3>
      {% for rule in legal.scooters %}
      <div class="legal-item"><strong>{{ rule.title }}</strong> — {{ rule.summary }} <a href="{{ rule.source }}" target="_blank" rel="noopener">Source</a></div>
      {% endfor %}
      {% endif %}
    </section>

    <section class="section" id="safety">
      <h2 class="section-title">Safety Evidence</h2>
      <p class="disclaimer">{{ safety.disclaimer }}</p>
      {% for stat in safety.stats %}
      <div class="stat-card">
        <strong>{{ stat.headline }}</strong>
        <p>{{ stat.detail }}</p>
        <p class="does-not"><em>Does NOT mean:</em> {{ stat.does_not_mean }}</p>
        <a href="{{ stat.url }}" target="_blank" rel="noopener">{{ stat.source }} ({{ stat.date }})</a>
      </div>
      {% endfor %}
    </section>
    </div>

    <section id="detailView" class="detail-view" hidden aria-label="Product details">
      <nav class="detail-breadcrumb">
        <button type="button" class="btn-back-detail" id="btnDetailBack">← Go back</button>
        <span id="detailBreadcrumb" class="detail-crumb"></span>
      </nav>
      <div class="detail-layout">
        <div id="detailGallery" class="detail-gallery"></div>
        <div id="detailBuyBox" class="detail-buybox"></div>
      </div>
      <div id="detailSpecs" class="detail-specs"></div>
      <div id="detailSimilar" class="detail-similar"></div>
      <div id="detailSubfooter" class="detail-subfooter">
        <div id="detailLegal" class="detail-footnote" hidden></div>
        <div id="detailFaq" class="detail-footnote" hidden></div>
      </div>
    </section>
  </div>

  <footer class="footer">
    <svg class="footer-waves" viewBox="0 0 1200 56" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,28 C200,8 400,44 600,24 C800,6 1000,40 1200,20 L1200,56 L0,56 Z" fill="rgba(255,255,255,0.12)"/>
      <path d="M0,36 C180,18 360,48 540,30 C720,14 900,46 1080,32 C1140,26 1175,38 1200,34 L1200,56 L0,56 Z" fill="rgba(255,255,255,0.08)"/>
    </svg>
    <p>Surf City HB · Generated {{ generated_date }} · <a href="{{ main_site_url }}">seanaguinaga.com</a> · Not legal or medical advice</p>
  </footer>

  <div id="compareDrawer" class="compare-drawer" hidden aria-hidden="true">
    <div class="compare-drawer-backdrop" id="compareDrawerBackdrop"></div>
    <aside class="compare-drawer-panel" role="dialog" aria-labelledby="compareDrawerTitle" aria-modal="true">
      <header class="compare-drawer-header">
        <h3 id="compareDrawerTitle">Side-by-Side Compare</h3>
        <button type="button" class="compare-drawer-close" id="btnCompareClose" aria-label="Close compare">✕</button>
      </header>
      <div class="compare-drawer-body">
        <p class="compare-drawer-hint" id="compareDrawerHint">Add rides with <strong>+ Compare</strong> on any card or detail page (up to 3).</p>
        <div class="compare-slots" id="compareSlots"></div>
        <div class="compare-diff" id="compareDiff" hidden></div>
        <div class="compare-matrix-wrap" id="compareMatrixWrap" hidden>
          <h4>🛡️ Safety Comparison</h4>
          <div id="compareMatrix"></div>
        </div>
      </div>
    </aside>
  </div>
  <button type="button" class="compare-fab" id="btnCompareFab" hidden aria-controls="compareDrawer">
    ⚖️ Compare <span class="compare-fab-count" id="compareFabCount">0</span>
  </button>

  <div id="chatDrawer" class="chat-drawer" hidden aria-hidden="true">
    <div class="chat-drawer-backdrop" id="chatDrawerBackdrop"></div>
    <aside class="chat-drawer-panel" role="dialog" aria-labelledby="chatDrawerTitle" aria-modal="true">
      <header class="chat-drawer-header">
        <div>
          <h3 id="chatDrawerTitle">Ryan</h3>
          <p class="chat-drawer-sub" id="chatDrawerSub">Your ride advisor — bikes, scooters, safety &amp; HB rules</p>
        </div>
        <button type="button" class="chat-drawer-close" id="btnChatClose" aria-label="Close chat">✕</button>
      </header>
      <div class="chat-messages" id="chatMessages" aria-live="polite"></div>
      <form class="chat-compose" id="chatForm">
        <div class="chat-suggestions" id="chatSuggestions"></div>
        <div class="chat-input-row">
          <input type="text" id="chatInput" placeholder="Ask Ryan about this ride, safety, or HB rules…" autocomplete="off" maxlength="500">
          <button type="submit" class="btn-primary chat-send" id="btnChatSend">Send</button>
        </div>
      </form>
    </aside>
  </div>
  <button type="button" class="chat-fab" id="btnChatFab" aria-controls="chatDrawer" aria-label="Chat with Ryan">
    💬 Ryan
  </button>

  <dialog class="modal" id="addBikeModal">
    <form method="dialog" id="addBikeForm">
      <h3>Add a bike</h3>
      <p class="modal-note">Saved in this browser only. Paste a product URL — we’ll try to pull name &amp; image; you confirm price, speed, and brakes.</p>
      <label>Product URL <input type="url" id="addBikeUrl" placeholder="https://…" required></label>
      <button type="button" class="btn-secondary" id="btnFetchUrl">Try fetch</button>
      <div class="form-grid">
        <label>Brand <input type="text" id="addBikeBrand" required></label>
        <label>Model <input type="text" id="addBikeModel" required></label>
        <label>Price (USD) <input type="number" id="addBikePrice" min="0" step="1" required></label>
        <label>Max speed (mph) <input type="number" id="addBikeSpeed" min="5" max="35" step="0.5" value="20"></label>
        <label>Class <select id="addBikeClass"><option value="1">1</option><option value="2" selected>2</option><option value="3">3</option></select></label>
        <label>Range PAS (mi) <input type="number" id="addBikeRange" min="0" step="1" placeholder="40"></label>
        <label>Capacity (Ah) <input type="number" id="addBikeAh" min="0" step="0.1" placeholder="10.4"></label>
        <label>Voltage (V) <input type="number" id="addBikeVoltage" min="0" step="1" placeholder="48"></label>
        <label>Charge time (hr) <input type="number" id="addBikeChargeHrs" min="0" step="0.5" placeholder="5"></label>
        <label>Charging <select id="addBikeChargeMethod">
          <option value="removable" selected>Removable pack</option>
          <option value="removable_keyed">Removable (keyed)</option>
          <option value="onboard">Onboard plug</option>
        </select></label>
        <label>Brakes <select id="addBikeBrake">
          <option value="rim">Rim</option>
          <option value="mechanical_disc" selected>Mechanical disc</option>
          <option value="hydraulic_disc">Hydraulic disc</option>
          <option value="coaster">Coaster</option>
        </select></label>
      </div>
      <div class="form-checks">
        <label><input type="checkbox" id="addBikeLightFront"> Front light</label>
        <label><input type="checkbox" id="addBikeLightRear"> Rear light</label>
        <label><input type="checkbox" id="addBikeUl"> UL battery cert</label>
      </div>
      <p id="addBikeStatus" class="modal-status" aria-live="polite"></p>
      <div class="modal-actions">
        <button type="button" class="btn-ghost" id="btnCancelAdd">Cancel</button>
        <button type="submit" class="btn-primary">Save bike</button>
      </div>
    </form>
  </dialog>

  <dialog class="modal" id="restoreModal">
    <form method="dialog">
      <h3>Hidden bikes</h3>
      <ul id="hiddenBikeList" class="hidden-bike-list"></ul>
      <div class="modal-actions">
        <button type="button" class="btn-secondary" id="btnRestoreAll">Restore all</button>
        <button type="submit" class="btn-primary">Done</button>
      </div>
    </form>
  </dialog>

  <script id="bikes-data" type="application/json">{{ bikes_json | safe }}</script>
  <script id="all-bikes-data" type="application/json">{{ all_bikes_json | safe }}</script>
  <script id="app-config" type="application/json">{"defaultBaselineId": "{{ default_baseline_id }}", "mainSiteUrl": "{{ main_site_url }}", "chatApiUrl": null}</script>
  <script id="tier-labels-data" type="application/json">{{ tier_labels_json | safe }}</script>
  <script id="legal-rules-data" type="application/json">{{ legal_json | safe }}</script>
  <script id="safety-data" type="application/json">{{ safety_json | safe }}</script>
  <script id="faq-data" type="application/json">{{ faq_json | safe }}</script>
  <script src="app.js?v={{ asset_version }}" defer></script>
</body>
</html>