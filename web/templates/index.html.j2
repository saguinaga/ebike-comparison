<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>E-Bike Comparison · Huntington Beach</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Palanquin+Dark:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <header class="hero">
    <h1>E-Bike Comparison</h1>
    <p>School rides · Surf City streets · {{ bikes|length }} bikes for a 5'2" 12-year-old in HB 92646</p>
    <nav class="quick-links">
      <a href="#safety">Safety Stats</a>
      <a href="#legal">HB Laws</a>
      <a href="#bikes">Compare Bikes</a>
      <a href="https://bit.ly/eBikeRiderTraining" target="_blank" rel="noopener">HBPD Training</a>
    </nav>
  </header>
  <div class="wave-divider"></div>

  <div class="container">
    <section class="baseline-panel" id="baseline">
      <h2 class="section-title">Baseline: {{ baseline.model }}</h2>
      <p><strong>${{ baseline.price_usd }}</strong> · Coaster brake · Single speed · Fits 5'2"–5'11" · Cruise 3–15 mph · Peak to 20–28 mph</p>
      <p>Your daughter's current bike. <a href="{{ baseline.url }}" target="_blank" rel="noopener">View on Firmstrong →</a></p>
    </section>

    <section class="section" id="bikes">
      <h2 class="section-title">Compare E-Bikes</h2>
      <div class="filter-bar">
        <label><input type="checkbox" id="colorFilter" checked> Show only white / light wood colors</label>
      </div>
      <div class="tier-tabs" id="tierTabs">
        <button class="tier-tab active" data-tier="all">All</button>
        {% for tier, label in tier_labels.items() if tier != 'baseline' %}
        <button class="tier-tab" data-tier="{{ tier }}">{{ label }}</button>
        {% endfor %}
      </div>
      <div class="card-grid" id="cardGrid">
        {% for bike in bikes %}
        <article class="bike-card" data-tier="{{ bike.tier }}" data-colors="{{ bike.colors | map(attribute='family') | join(',') }}">
          <h3>{{ bike.brand }} {{ bike.model }}</h3>
          <div class="price-big">${{ bike.landed_price_usd or bike.price_usd }}</div>
          <div class="badges">
            <span class="badge sage">Safety {{ bike.safety_score }}/100</span>
            {% if bike.legal.legal_for_age %}
            <span class="badge sage">Legal at 12</span>
            {% else %}
            <span class="badge danger">Illegal at 12</span>
            {% endif %}
            {% if bike.friend_recommended %}
            <span class="badge info">Friend recommended</span>
            {% endif %}
            <span class="badge info">Class {{ bike.e_bike_class }}</span>
          </div>
          <p>{{ tier_labels.get(bike.tier, bike.tier) }} · {{ bike.max_speed_mph }} mph · {{ bike.brake_type | replace('_', ' ') }}</p>
          <p>vs Firmstrong: <strong>{{ bike.vs_baseline.price_multiplier }}×</strong> price · +{{ bike.vs_baseline.speed_delta_mph }} mph</p>
          <div class="color-swatches">
            {% for c in bike.colors %}
            <span class="swatch {{ c.family }}" title="{{ c.name }}"></span>
            {% endfor %}
          </div>
          {% if bike.tier == 'budget' %}
          <ul class="checklist">
            {% for item in bike.safety_checklist %}
            <li class="{{ 'ok' if item.ok else 'miss' }}">{{ item.label }}</li>
            {% endfor %}
          </ul>
          {% endif %}
          {% for badge in bike.legal.badges %}
          <span class="badge {{ badge.type }}">{{ badge.text }}</span>
          {% endfor %}
        </article>
        {% endfor %}
      </div>
    </section>

    <section class="section" id="table-section">
      <h2 class="section-title">Sortable Overview</h2>
      <table class="compare" id="compareTable">
        <thead>
          <tr>
            <th>Bike</th>
            <th>Price</th>
            <th>Safety</th>
            <th>Class</th>
            <th>Legal 12?</th>
            <th>Max mph</th>
            <th>Brakes</th>
          </tr>
        </thead>
        <tbody>
          {% for bike in bikes %}
          <tr data-tier="{{ bike.tier }}">
            <td>{{ bike.brand }} {{ bike.model }}</td>
            <td>${{ bike.landed_price_usd or bike.price_usd }}</td>
            <td>{{ bike.safety_score }}</td>
            <td>{{ bike.e_bike_class }}</td>
            <td>{{ 'Yes' if bike.legal.legal_for_age else 'NO' }}</td>
            <td>{{ bike.max_speed_mph }}</td>
            <td>{{ bike.brake_type }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </section>

    <section class="section" id="legal">
      <h2 class="section-title">Legal: California + Huntington Beach</h2>
      <p class="disclaimer">{{ legal.disclaimer }}</p>
      {% for rule in legal.california %}
      <div class="legal-item">
        <strong>{{ rule.title }}</strong>
        <p>{{ rule.summary }} <a href="{{ rule.source }}" target="_blank" rel="noopener">Source →</a></p>
      </div>
      {% endfor %}
      {% for rule in legal.huntington_beach %}
      <div class="legal-item">
        <strong>{{ rule.title }}</strong>
        <p>{{ rule.summary }} <a href="{{ rule.source }}" target="_blank" rel="noopener">Source →</a></p>
      </div>
      {% endfor %}
    </section>

    <section class="section" id="safety">
      <h2 class="section-title">Safety Evidence</h2>
      <p class="disclaimer">{{ safety.disclaimer }}</p>
      {% for stat in safety.stats %}
      <div class="stat-card">
        <strong>{{ stat.headline }}</strong>
        <p>{{ stat.detail }}</p>
        <p class="does-not"><em>What this does NOT mean:</em> {{ stat.does_not_mean }}</p>
        <a href="{{ stat.url }}" target="_blank" rel="noopener">{{ stat.source }} ({{ stat.date }}) →</a>
      </div>
      {% endfor %}
    </section>
  </div>

  <footer class="footer">
    <p><a href="{{ main_site_url }}">← Back to main site</a> · Generated {{ generated_date }}</p>
    <p>Not medical or legal advice. Verify laws and fit before buying.</p>
  </footer>
  <script src="app.js"></script>
</body>
</html>